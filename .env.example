# 'mock' = offline demo with zero credentials | 'live' = real ServiceNow + Azure OpenAI
APP_MODE=live

# ServiceNow PDI (developer.servicenow.com)
SNOW_INSTANCE_URL=https://devXXXXX.service-now.com
SNOW_OAUTH_CLIENT_ID=
SNOW_OAUTH_CLIENT_SECRET=
SNOW_USERNAME=admin
SNOW_PASSWORD=
SNOW_OAUTH_GRANT_TYPE=password

# Azure OpenAI (leave endpoint empty to fall back to standard OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
OPENAI_API_KEY=

# Pipeline
ROUTING_CONFIDENCE_THRESHOLD=0.7
FALLBACK_ASSIGNMENT_GROUP=L1 Service Desk
WEBHOOK_SHARED_SECRET=change-me
